# Notification Configuration
# Set to 'true' to enable the respective notification service
ENABLE_TELEGRAM=false
ENABLE_PUSHOVER=false
ENABLE_DESKTOP=true
ENABLE_EMAIL=false

# Telegram Settings
# Create a bot via @BotFather to get your token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Get your Chat ID via @userinfobot or similar
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Pushover Settings
PUSHOVER_USER_KEY=your_pushover_user_key_here
PUSHOVER_API_TOKEN=your_pushover_api_token_here

# Email Settings (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
EMAIL_TO=recipient_email@gmail.com

# Scraper Settings
# Time in milliseconds to wait for page navigation/loading
PLAYWRIGHT_TIMEOUT=30000
# Run headlessly or headfully
HEADLESS=true

# AI Summarization Settings (Optional)
# Get a free API Key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Dashboard Password (Optional)
# Set a password to encrypt the static dashboard HTML for secure hosting
DASHBOARD_PASSWORD=your_secure_password_here
